        /* Reviews Section */
        .reviews-section {
            padding: 80px 0;
            position: relative;
            z-index: 10;
            background: #1a1a1a;
        }

        .reviews-section .highlight-green {
            color: #00dc82;
        }

        .reviews-header {
            text-align: center;
            margin-bottom: 48px;
        }

        .reviews-header .section-title {
            font-size: clamp(28px, 4vw, 48px);
            font-weight: 800;
            color: var(--text);
            margin: 0;
            letter-spacing: -0.5px;
        }

        .reviews-content {
            display: flex;
            flex-direction: column;
            gap: 48px;
            align-items: center;
            max-width: 1000px;
            margin: 0 auto;
        }

        .review-video-wrapper {
            text-align: center;
            margin-bottom: 40px;
        }

        .review-video-container {
            position: relative;
            display: inline-block;
            width: 100%;
            max-width: 400px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
            transition: all 0.3s ease;
        }

        .review-video-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 60px rgba(0, 220, 130, 0.2);
        }

        .review-video {
            width: 100%;
            height: auto;
            display: block;
            background: #000;
            border-radius: 16px;
            user-select: none;
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            pointer-events: auto;
        }

        .review-video::-webkit-media-controls {
            display: flex !important;
        }

        .review-video::-webkit-media-controls-enclosure {
            display: flex !important;
        }

        .review-video::-webkit-media-controls-panel {
            display: flex !important;
        }

        .review-video-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 220, 130, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
            border-radius: 16px;
            cursor: pointer;
        }

        .review-video-container:hover .review-video-overlay {
            opacity: 1;
        }

        .review-play-button {
            width: 80px;
            height: 80px;
            background: linear-gradient(
                135deg,
                var(--accent) 0%,
                var(--accent-bright) 100%
            );
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 25px rgba(0, 220, 130, 0.4);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .review-play-button:hover {
            transform: scale(1.1);
            box-shadow: 0 12px 35px rgba(0, 220, 130, 0.6);
        }

        .review-play-icon {
            color: var(--bg);
            font-size: 24px;
            font-weight: bold;
            margin-left: 3px;
        }

        .review-images-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 32px;
            width: 100%;
            max-width: 1000px;
        }

        .review-image-item {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
            background: var(--bg-elevated);
            border: 1px solid var(--border);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .review-image-item:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 50px rgba(0, 220, 130, 0.2);
        }

        .review-image {
            width: 100%;
            height: auto;
            display: block;
        }

        @media (max-width: 768px) {
            .reviews-section {
                padding: 60px 0;
