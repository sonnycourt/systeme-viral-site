            async generatePersonalizedRecommendations() {
                const recommendationsContainer = document.getElementById(
                    "recommendations-container",
                );
                const recommendationsLoading = document.getElementById(
                    "recommendations-loading",
                );
                const recommendationsContent = document.getElementById(
                    "recommendations-content",
                );

                if (recommendationsContainer) {
                    recommendationsContainer.style.display = "block";
                }

                if (recommendationsLoading) {
                    recommendationsLoading.style.display = "block";
                }

                if (recommendationsContent) {
                    recommendationsContent.style.display = "none";
                }

                try {
                    const response = await fetch(
                        "/.netlify/functions/recommendations",
                        {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                            },
                            body: JSON.stringify({
                                answers: this.answers,
                                score: this.calculateScore(),
                            }),
                        },
                    );

                    // Lire la réponse
                    const text = await response.text();
                    let data;

                    try {
                        data = JSON.parse(text);
                    } catch (jsonError) {
                        console.error("Erreur parsing JSON:", jsonError);
                        console.error("Response text:", text);
                        throw new Error(
                            `Erreur serveur (${response.status}): Réponse invalide`,
                        );
                    }

                    if (!response.ok) {
                        console.error(
                            "Response not OK:",
                            response.status,
                            data,
                        );
                        throw new Error(
                            data.error ||
                                data.details ||
                                `Erreur serveur (${response.status})`,
                        );
                    }

                    if (!data || !data.recommendations) {
                        throw new Error("Format de réponse invalide de l'API");
                    }

                    if (recommendationsLoading) {
                        recommendationsLoading.style.display = "none";
                    }

                    if (recommendationsContent) {
                        recommendationsContent.style.display = "block";
                        // Préserver le HTML (notamment les liens) et convertir les sauts de ligne
                        let content = data.recommendations;

                        // Protéger les balises HTML existantes avant de convertir les sauts de ligne
                        const htmlTags = [];
                        content = content.replace(/<[^>]+>/g, (match) => {
                            htmlTags.push(match);
                            return `__HTML_TAG_${htmlTags.length - 1}__`;
                        });

                        // Convertir les sauts de ligne
                        content = content
                            .replace(/\n\n/g, "</p><p>")
                            .replace(/\n/g, "<br>");

                        // Restaurer les balises HTML
                        htmlTags.forEach((tag, index) => {
                            content = content.replace(
                                `__HTML_TAG_${index}__`,
                                tag,
                            );
                        });

                        recommendationsContent.innerHTML = `<p>${content}</p>`;
                    }
                } catch (error) {
                    console.error(
                        "Erreur lors de la génération des recommandations:",
                        error,
                    );

                    if (recommendationsLoading) {
                        recommendationsLoading.style.display = "none";
                    }

                    if (recommendationsContent) {
                        recommendationsContent.style.display = "block";
                        // Afficher plus de détails en mode développement
                        const errorMessage =
                            error instanceof Error
                                ? error.message
                                : String(error);
                        console.log("Erreur complète:", {
                            message: errorMessage,
                            answers: this.answers,
                            score: this.calculateScore(),
                        });

                        recommendationsContent.innerHTML = `
                            <div style="text-align: center; color: #666;">
                                <p>⚠️ Impossible de charger les recommandations personnalisées pour le moment.</p>
                                <p>Continue avec la formation - elle est adaptée à tous les profils !</p>
                                <p style="font-size: 12px; margin-top: 10px; color: #444;">
                                    (Erreur: ${errorMessage})
                                </p>
                            </div>
                        `;
                    }
                }
            }

            restart() {
                this.currentQuestionIndex = 0;
                this.answers = [];
                this.totalScore = 0;

                const calculatorContent = document.querySelector(
                    ".calculator-content",
                ) as HTMLElement;
                const resultsContainer = document.getElementById(
                    "results-container",
                ) as HTMLElement;

                if (calculatorContent) calculatorContent.style.display = "flex";
                if (resultsContainer) resultsContainer.style.display = "none";

                this.showQuestion(0);
            }
        }

        // Initialize calculator when DOM is loaded
        let calculator;

        // Function to initialize calculator
        function initCalculator() {
            calculator = new SuccessCalculator();
            // Make calculator available globally for onclick handlers
            window.calculator = calculator;

            // Guard against unexpected DOM rewrites: re-render premium card if stripped
            const qc = document.getElementById("question-container");
            if (qc) {
                const observer = new MutationObserver(() => {
                    // if premium container missing, re-render current question
                    if (!qc.querySelector(".question-card-premium")) {
                        if (
                            window.calculator &&
                            typeof window.calculator.showQuestion === "function"
                        ) {
                            window.calculator.showQuestion(
                                window.calculator.currentQuestionIndex || 0,
                            );
                        }
                    }
                });
                observer.observe(qc, { childList: true, subtree: true });
            }
        }

        // Initialize immediately if DOM is ready, otherwise wait
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initCalculator);
        } else {
            initCalculator();
        }
        // Timeline Scroll Animations
        const initTimelineAnimations = () => {
            const timelineSteps = document.querySelectorAll(".timeline-step");

            const observerOptions = {
                threshold: 0.2,
                rootMargin: "-100px 0px -100px 0px",
            };

            // Intersection Observer for module animations
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("active");
                        }
                    });
                },
                { threshold: 0.3 },
            );

            timelineSteps.forEach((step) => {
                observer.observe(step);
            });

            // Timeline line progress effect
            const roadmapSection = document.querySelector(".roadmap-section");
            const timelineLine = document.querySelector(".timeline-line");

            if (roadmapSection && timelineLine && timelineSteps.length > 0) {
                const handleScroll = () => {
                    const rect = roadmapSection.getBoundingClientRect();
                    const viewportHeight = window.innerHeight;

                    // Calcul simple : pourcentage de scroll dans la section
                    const sectionTop = rect.top;
                    const sectionHeight = rect.height;

                    let progress = 0;
                    if (
                        sectionTop < viewportHeight &&
                        sectionTop > -sectionHeight
                    ) {
                        const baseProgress = Math.max(
                            0,
                            Math.min(
                                1,
                                (viewportHeight - sectionTop) /
                                    (viewportHeight + sectionHeight),
                            ),
                        );

                        // Accélérer la progression après 50% (module 6 environ)
                        if (baseProgress > 0.5) {
                            const acceleratedProgress =
                                0.5 + (baseProgress - 0.5) * 1.5;
                            progress = Math.min(1, acceleratedProgress);
                        } else {
                            progress = baseProgress;
                        }
                    }

                    // Ligne suit directement le scroll
                    (timelineLine as HTMLElement).style.height =
                        `${progress * 100}%`;
                };

                window.addEventListener("scroll", handleScroll);
                handleScroll(); // Initial call

                // Inject timeline stop dots positioned exactly on the line
                const timeline = document.querySelector(
                    ".roadmap-timeline",
                ) as HTMLElement | null;
                const steps = Array.from(
                    document.querySelectorAll(".timeline-step"),
                ) as HTMLElement[];
                if (timeline && steps.length) {
                    // Remove existing stops to avoid duplicates on HMR
                    timeline
                        .querySelectorAll(".timeline-stop")
                        .forEach((n) => n.remove());

                    const timelineRect = timeline.getBoundingClientRect();
                    const lineX = timelineRect.width / 2; // since line is at 50%

                    steps.forEach((step) => {
                        const stepRect = step.getBoundingClientRect();
                        const stepCenterY =
                            step.offsetTop + stepRect.height / 2;

                        const dot = document.createElement("div");
                        dot.className = "timeline-stop";
                        dot.style.left = `${lineX}px`;
                        dot.style.top = `${stepCenterY}px`;
                        timeline.appendChild(dot);
                    });
                }
            }
        };

        // Initialize timeline animations
        if (document.readyState === "loading") {
            document.addEventListener(
                "DOMContentLoaded",
                initTimelineAnimations,
            );
        } else {
            initTimelineAnimations();
        }
        // Case study video play functionality
        document.addEventListener("DOMContentLoaded", function () {
            const playButton = document.querySelector(".play-button");
            const video = document.querySelector(".case-study-video");
            const overlay = document.querySelector(".image-overlay");

            if (playButton && video && overlay) {
                // Click on play button - start video, show controls and hide overlay
                playButton.addEventListener("click", function () {
                    video.play();
                    video.controls = true; // Show controls after play
                    overlay.style.opacity = "0";
                    overlay.style.pointerEvents = "none";
                });

                // Click on video area (not controls) - toggle play/pause
                video.addEventListener("click", function (e) {
                    // Only if click is not on controls
                    if (e.target === video) {
                        if (video.paused) {
                            video.play();
                            video.controls = true; // Show controls when playing
                        } else {
                            video.pause();
                        }
                    }
                });

                // Hide overlay when video starts playing
                video.addEventListener("play", function () {
                    overlay.style.opacity = "0";
                    overlay.style.pointerEvents = "none";
                });

                // Show overlay when video is paused
                video.addEventListener("pause", function () {
                    overlay.style.opacity = "1";
                    overlay.style.pointerEvents = "auto";
                });
            }

            // Review video play functionality
            const reviewPlayButton = document.querySelector(".review-play-button");
            const reviewVideo = document.querySelector(".review-video") as HTMLVideoElement | null;
            const reviewOverlay = document.querySelector(".review-video-overlay") as HTMLElement | null;

            if (reviewPlayButton && reviewVideo && reviewOverlay) {
                let isUserPaused = false;
                let isPlaying = false;
                let clickTimeout: ReturnType<typeof setTimeout> | null = null;

                // Function to start video
                const startVideo = () => {
                    if (clickTimeout) {
                        clearTimeout(clickTimeout);
                        clickTimeout = null;
                    }
                    isUserPaused = false;
                    isPlaying = true;
                    reviewVideo.play().catch(() => {
                        // Ignore play errors
                    });
                    reviewVideo.controls = true;
                    reviewOverlay.style.opacity = "0";
                    reviewOverlay.style.pointerEvents = "none";
                };

                // Function to pause video
                const pauseVideo = () => {
                    if (clickTimeout) {
                        clearTimeout(clickTimeout);
                        clickTimeout = null;
                    }
                    isUserPaused = true;
                    isPlaying = false;
                    reviewVideo.pause();
                    reviewOverlay.style.opacity = "1";
                    reviewOverlay.style.pointerEvents = "auto";
                };

                // Click on play button - start video
                reviewPlayButton.addEventListener("click", function (e) {
                    e.stopPropagation();
                    e.preventDefault();
                    startVideo();
                });

                // Click on overlay - start video
                reviewOverlay.addEventListener("click", function (e) {
                    e.stopPropagation();
                    e.preventDefault();
                    startVideo();
                });

                // Click on video area (not controls) - toggle play/pause
                reviewVideo.addEventListener("click", function (e) {
                    // Don't interfere with controls clicks
                    const target = e.target as HTMLElement;
                    if (target.closest('.review-video-overlay')) {
                        return;
                    }
                    
                    // Check if click is on video controls (play/pause button, etc.)
                    const isControlClick = target.closest('video') !== reviewVideo || 
                                          target.tagName === 'BUTTON' ||
                                          target.closest('button');
                    
                    if (!isControlClick) {
                        e.preventDefault();
                        e.stopPropagation();
                        
                        // Small delay to avoid conflicts with native controls
                        if (clickTimeout) {
                            clearTimeout(clickTimeout);
                        }
                        
                        clickTimeout = setTimeout(() => {
                            if (reviewVideo.paused) {
                                startVideo();
                            } else {
                                pauseVideo();
                            }
                        }, 50);
                    }
                });

                // Hide overlay when video starts playing
                reviewVideo.addEventListener("play", function () {
                    isPlaying = true;
                    if (!isUserPaused) {
                        reviewOverlay.style.opacity = "0";
                        reviewOverlay.style.pointerEvents = "none";
                    }
                });

                // Show overlay when video is paused (only if user paused it)
                reviewVideo.addEventListener("pause", function () {
                    isPlaying = false;
                    // Only show overlay if user manually paused, not if it's a buffering pause
                    if (isUserPaused && !reviewVideo.seeking) {
                        setTimeout(() => {
                            if (reviewVideo.paused && isUserPaused) {
                                reviewOverlay.style.opacity = "1";
                                reviewOverlay.style.pointerEvents = "auto";
                            }
                        }, 100);
                    }
                });

                // Handle seeking to prevent overlay from showing during buffering
                reviewVideo.addEventListener("seeking", function () {
                    isUserPaused = false;
                });

                // Disable right-click context menu on video
                reviewVideo.addEventListener("contextmenu", function (e) {
                    e.preventDefault();
                    return false;
                });

                // Disable download via keyboard shortcuts
                reviewVideo.addEventListener("keydown", function (e) {
                    // Disable Ctrl+S, Ctrl+Shift+S, etc.
                    if ((e.ctrlKey || e.metaKey) && (e.key === "s" || e.key === "S")) {
                        e.preventDefault();
                        return false;
                    }
                });
            }
        });
        // FAQ Accordion functionality
        document.addEventListener("DOMContentLoaded", function () {
            const faqItems = document.querySelectorAll(".faq-item");

            faqItems.forEach((item) => {
                const question = item.querySelector(".faq-question");
                const answer = item.querySelector(".faq-answer");
                const icon = item.querySelector(".faq-icon");

                question.addEventListener("click", function () {
                    const isOpen = answer.style.display === "block";

                    // Close all other FAQ items
                    faqItems.forEach((otherItem) => {
                        const otherAnswer =
                            otherItem.querySelector(".faq-answer");
                        const otherIcon = otherItem.querySelector(".faq-icon");
                        otherAnswer.style.display = "none";
                        otherIcon.style.transform = "rotate(0deg)";
                        otherItem.style.background =
                            "rgba(255, 255, 255, 0.02)";
                    });

                    // Toggle current item
                    if (!isOpen) {
                        answer.style.display = "block";
                        icon.style.transform = "rotate(180deg)";
                        item.style.background = "rgba(1, 233, 136, 0.05)";
                    }
                });
            });
        });
    </script>
