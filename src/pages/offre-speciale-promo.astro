    <!-- Video Controls Script (from 100k-masterclass) -->
    <script>
        // Custom Video Controls for offre-speciale
        function initOffreVideo() {
            const offreVideo = document.getElementById(
                "offre-video",
            ) as HTMLVideoElement | null;
            const offreWrapper = document.querySelector(
                ".video-wrapper-offre",
            ) as HTMLElement | null;
            const bigPlayOffre = document.getElementById("bigPlayOffre");
            const playPauseOffre = document.getElementById("playPauseOffre");
            const progressSliderOffre = document.getElementById(
                "progressSliderOffre",
            ) as HTMLInputElement | null;
            const volumeSliderOffre = document.getElementById(
                "volumeSliderOffre",
            ) as HTMLInputElement | null;

            if (!offreVideo || !offreWrapper) return;

            function setPlayingStateOffre(isPlaying: boolean) {
                if (!offreWrapper) return;
                if (isPlaying) {
                    offreWrapper.classList.add("is-playing-offre");
                    bigPlayOffre?.classList.add("hidden");
                } else {
                    offreWrapper.classList.remove("is-playing-offre");
                    bigPlayOffre?.classList.remove("hidden");
                }
            }

            function togglePlayOffre() {
                if (!offreVideo) return;
                if (offreVideo.paused) {
                    offreVideo.play();
                } else {
                    offreVideo.pause();
                }
            }

            offreVideo.removeAttribute("controls");

            bigPlayOffre?.addEventListener("click", togglePlayOffre);
            playPauseOffre?.addEventListener("click", togglePlayOffre);
            offreVideo.addEventListener("click", togglePlayOffre);

            offreVideo.addEventListener("play", () =>
                setPlayingStateOffre(true),
            );
            offreVideo.addEventListener("pause", () =>
                setPlayingStateOffre(false),
            );

            // Progress bar control
            let isDraggingProgress = false;

            // Update progress bar as video plays
            offreVideo.addEventListener("timeupdate", () => {
                if (
                    !isDraggingProgress &&
                    progressSliderOffre &&
                    offreVideo.duration
                ) {
                    const progress =
                        (offreVideo.currentTime / offreVideo.duration) * 100;
                    progressSliderOffre.value = progress.toString();
                }
            });

            // Update video position when progress bar is dragged
            progressSliderOffre?.addEventListener("input", () => {
                if (!offreVideo || !progressSliderOffre || !offreVideo.duration)
                    return;
                isDraggingProgress = true;
                const progress = parseFloat(progressSliderOffre.value);
                offreVideo.currentTime = (progress / 100) * offreVideo.duration;
            });

            progressSliderOffre?.addEventListener("mousedown", () => {
                isDraggingProgress = true;
            });

            progressSliderOffre?.addEventListener("mouseup", () => {
                isDraggingProgress = false;
            });

            progressSliderOffre?.addEventListener("touchstart", () => {
                isDraggingProgress = true;
            });

            progressSliderOffre?.addEventListener("touchend", () => {
                isDraggingProgress = false;
            });

            // Initialize progress bar when video metadata is loaded
            offreVideo.addEventListener("loadedmetadata", () => {
                if (progressSliderOffre && offreVideo.duration) {
                    progressSliderOffre.max = "100";
                    progressSliderOffre.value = "0";
                }
            });

            // Volume control
            volumeSliderOffre?.addEventListener("input", (e) => {
                const value = parseFloat((e.target as HTMLInputElement).value);
                if (!isNaN(value) && offreVideo) {
                    offreVideo.volume = value;
                    if (offreVideo.volume === 0) {
                        offreVideo.muted = true;
                    } else {
                        offreVideo.muted = false;
                    }
                }
            });

            // Prevent keyboard seeking
            offreVideo.addEventListener("keydown", (e: KeyboardEvent) => {
                const keysToBlock = [
                    "ArrowLeft",
                    "ArrowRight",
                    "Home",
                    "End",
                    "PageUp",
                    "PageDown",
                    "j",
                    "l",
                ];
                if (keysToBlock.includes(e.key)) {
                    e.preventDefault();
                    e.stopPropagation();
                }
            });
        }

        // Initialize when DOM is ready
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initOffreVideo);
        } else {
            initOffreVideo();
        }
    </script>

