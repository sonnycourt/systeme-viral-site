    <script>
        // Countdown timer - Updated 2025
        const endDate = (window as any).__PROMO_DEADLINE__ || new Date("2026-01-03T23:59:59+01:00").getTime();

        const attachTimerToCta = (node: HTMLElement) => {
            if (node.querySelector(".cta-timer")) return;

            const timerWrapper = document.createElement("div");
            timerWrapper.classList.add("cta-timer");

            timerWrapper.innerHTML = `
                <div class="cta-timer-unit">
                    <span class="cta-timer-value" data-unit="days">00</span>
                    <span class="cta-timer-label">Jours</span>
                </div>
                <div class="cta-timer-unit">
                    <span class="cta-timer-value" data-unit="hours">00</span>
                    <span class="cta-timer-label">Heures</span>
                </div>
                <div class="cta-timer-unit">
                    <span class="cta-timer-value" data-unit="minutes">00</span>
                    <span class="cta-timer-label">Minutes</span>
                </div>
                <div class="cta-timer-unit">
                    <span class="cta-timer-value" data-unit="seconds">00</span>
                    <span class="cta-timer-label">Secondes</span>
                </div>
            `;

            node.appendChild(timerWrapper);
        };

        const disablePurchaseCtas = () => {
            const selectors = [
                'a[href*="systemeviral.spiffy.co"]',
                ".result-cta",
                ".video-cta-btn",
                ".target-cta a",
                ".bonus-cta a",
                ".guarantee-cta a",
                ".cta-final a",
                ".cta-wrapper a",
                ".proof-cta a",
            ].join(", ");

            document
                .querySelectorAll<HTMLElement>(selectors)
                .forEach((node) => {
                    if (node.classList.contains("countdown-cta-button")) {
                        return;
                    }
                    node.classList.add("cta-disabled");
                    node.setAttribute("aria-disabled", "true");
                    node.setAttribute("tabindex", "-1");

                    if (node instanceof HTMLAnchorElement) {
                        const originalHref = node.getAttribute("href");
                        if (originalHref) {
                            node.setAttribute(
                                "data-original-href",
                                originalHref,
                            );
                        }
                        node.removeAttribute("href");
                        node.removeAttribute("target");
                    }

                    if (node instanceof HTMLButtonElement) {
                        node.disabled = true;
                    }

                    attachTimerToCta(node);
                });
        };

        const updateCtaTimersDetailed = (
            days: number,
            hours: number,
            minutes: number,
            seconds: number,
        ) => {
            const values: Record<string, number> = {
                days,
                hours,
                minutes,
                seconds,
            };

            document
                .querySelectorAll<HTMLElement>(".cta-timer")
                .forEach((timer) => {
                    Object.entries(values).forEach(([unit, value]) => {
                        const target = timer.querySelector<HTMLElement>(
                            `[data-unit="${unit}"]`,
                        );
                        if (target) {
                            target.textContent = value
                                .toString()
                                .padStart(2, "0");
                        }
                    });
                });
        };

        // Mise à jour du compte à rebours (pour la section du bas uniquement)
        const updateCountdown = () => {
            const now = new Date().getTime();
            const distance = endDate - now;

            if (distance < 0) {
                updateCtaTimersDetailed(0, 0, 0, 0);
                return;
            }

            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor(
                (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
            );
            const minutes = Math.floor(
                (distance % (1000 * 60 * 60)) / (1000 * 60),
            );
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            updateCtaTimersDetailed(days, hours, minutes, seconds);

            // Countdown du bas
            document.getElementById("daysBottom").textContent = days
                .toString()
                .padStart(2, "0");
            document.getElementById("hoursBottom").textContent = hours
                .toString()
                .padStart(2, "0");
            document.getElementById("minutesBottom").textContent = minutes
                .toString()
                .padStart(2, "0");
            document.getElementById("secondsBottom").textContent = seconds
                .toString()
                .padStart(2, "0");

            if (days === 0) {
                // Effets visuels pour le countdown du bas
                document
                    .querySelectorAll(
                        "#daysBottom, #hoursBottom, #minutesBottom, #secondsBottom",
                    )
                    .forEach((el) => {
                        el.style.borderColor = "#03f18d";
                        el.style.color = "#ffffff";
                        el.style.boxShadow = "0 0 15px rgba(3, 241, 141, 0.45)";
                        el.style.animation = "urgentPulse 0.8s infinite";
                    });
                const discountBadge = document.querySelector(".discount-badge");
                if (discountBadge) {
                    (discountBadge as HTMLElement).style.animation = "pulse 1s infinite";
                    (discountBadge as HTMLElement).style.borderColor = "#03f18d";
                    (discountBadge as HTMLElement).style.boxShadow = "0 0 20px rgba(3, 241, 141, 0.5)";
                }
            }
        };

        // Initialisation
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", function () {
                // disablePurchaseCtas(); // Désactivé pour garder les boutons normaux
                updateCountdown();
                setInterval(updateCountdown, 1000);
            });
        } else {
            // disablePurchaseCtas(); // Désactivé pour garder les boutons normaux
            updateCountdown();
            setInterval(updateCountdown, 1000);
        }
        // Chatbot functionality
        let chatbotOpen = false;
        const chatbotToggle = document.getElementById(
            "chatbot-toggle",
