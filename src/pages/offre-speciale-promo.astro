    <script>
        // Système de séquence de 7 jours pour Système Viral
        interface SequenceConfig {
            day: number;
            places: number;
            discount: number;
            badgeText: string;
        }

        // Paliers horaires pour l'interpolation
        const hourlyThresholds = [
            { hours: 0, places: 15 },    // 0h
            { hours: 24, places: 12 },   // 24h
            { hours: 48, places: 8 },    // 48h
            { hours: 72, places: 6 },    // 72h
            { hours: 96, places: 4 },    // 96h
            { hours: 120, places: 3 },   // 120h
            { hours: 144, places: 2 },   // 144h
            { hours: 168, places: 0 }    // 168h (7 jours)
        ];

        // Config pour preview mode (par jour)
        const previewConfigs: Record<number, { places: number, badgeText: string }> = {
            1: { places: 15, badgeText: 'OFFRE LANCEMENT 2.0' },
            2: { places: 12, badgeText: 'OFFRE LANCEMENT 2.0' },
            3: { places: 8, badgeText: 'OFFRE LANCEMENT 2.0' },
            4: { places: 6, badgeText: 'OFFRE LANCEMENT 2.0' },
            5: { places: 4, badgeText: 'OFFRE LANCEMENT 2.0' },
            6: { places: 3, badgeText: 'OFFRE LANCEMENT 2.0' },
            7: { places: 2, badgeText: 'OFFRE LANCEMENT 2.0' }
        };

        // Variable globale pour stocker les places (utilisée par le visitor counter)
        let globalPlacesRemaining = 15;

        // Fonction pour obtenir les places en mode preview uniquement
        function getPreviewPlaces(): number | null {
            const urlParams = new URLSearchParams(window.location.search);
            const previewParam = urlParams.get('preview');
            
            // Preview mode: ?preview=1 à ?preview=8 (8 = fermé)
            if (previewParam) {
                const day = parseInt(previewParam);
                if (!isNaN(day)) {
                    if (day >= 8) {
                        console.log('🔍 Mode preview: Jour 8+ (Offre fermée)');
                        return 0;
                    }
                    if (day >= 1 && day <= 7) {
                        const config = previewConfigs[day];
                        console.log(`🔍 Mode preview: Jour ${day} - ${config.places} places`);
                        return config.places;
                    }
                }
            }
            
            return null; // Pas en mode preview
        }

        async function initializeSequence() {
            let placesRemaining: number;
            
            // Check for preview mode first
            const previewPlaces = getPreviewPlaces();
            if (previewPlaces !== null) {
                placesRemaining = previewPlaces;
            } else {
                // Production mode: lire token depuis URL uniquement (pas localStorage)
                const urlParams = new URLSearchParams(window.location.search);
                const token = urlParams.get('token');
                
                if (token && token.startsWith('sv_')) {
                    try {
                        const res = await fetch(`/.netlify/functions/check-places-sv?token=${encodeURIComponent(token)}`);
                        const data = await res.json();
                        if (data.valid && typeof data.placesRemaining === 'number') {
                            placesRemaining = data.placesRemaining;
                            console.log('✅ Places from Blobs:', placesRemaining);
                        } else {
                            // Token pas dans Blobs → l'enregistrer MAINTENANT avec timestamp actuel
                            console.log('⚠️ Token not in Blobs, registering now');
                            const startTime = Math.floor(Date.now() / 1000);
                            try {
                                await fetch('/.netlify/functions/init-places-sv', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ token, startTime })
                                });
                                // Token vient d'être créé → 15 places (début de séquence)
                                placesRemaining = 15;
                                console.log('✅ Token registered in Blobs, starting with 15 places');
                            } catch (initError) {
                                console.error('❌ Failed to register token:', initError);
                                placesRemaining = 15;
                            }
                        }
                    } catch (e) {
                        console.error('❌ API error:', e);
                        // Erreur réseau → par défaut 15 places
                        placesRemaining = 15;
                    }
                } else {
                    // Pas de token → par défaut 15 places
                    console.log('⚠️ No token in URL, defaulting to 15 places');
                    placesRemaining = 15;
                }
            }
            
            // Store globally for visitor counter
            globalPlacesRemaining = placesRemaining;

            // Handle closed state
            if (placesRemaining === 0) {
                // Hide urgent counter (top)
                const urgentCounter = document.getElementById('urgent-counter');
                const ctaSection = document.querySelector('.cta-section');
                const soldOutState = document.getElementById('sold-out-state');
                
                // Hide urgent counter (bottom)
                const urgentCounterBottom = document.getElementById('urgent-counter-bottom');
                
                if (urgentCounter) {
                    (urgentCounter as HTMLElement).style.display = 'none';
                }
                if (urgentCounterBottom) {
                    (urgentCounterBottom as HTMLElement).style.display = 'none';
                }
                if (ctaSection) {
                    (ctaSection as HTMLElement).style.display = 'none';
                }
                if (soldOutState) {
                    (soldOutState as HTMLElement).style.display = 'block';
                }

                // Disable all CTA buttons
                const ctaButtons = document.querySelectorAll('a[href*="checkout"], a[href*="spiffy"], .cta-button, .countdown-cta-button, .cta-button-final, button[class*="cta"], a[class*="cta"]');
                ctaButtons.forEach((button) => {
                    const btn = button as HTMLElement;
                    btn.style.opacity = '0.5';
                    btn.style.cursor = 'not-allowed';
                    btn.style.pointerEvents = 'none';
                    btn.style.filter = 'grayscale(100%)';
                    if (btn.tagName === 'A') {
                        const originalHref = btn.getAttribute('href');
                        btn.setAttribute('data-original-href', originalHref || '');
                        btn.setAttribute('href', '#');
                        btn.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            return false;
                        });
                    }
                });

                // Hide visitor sticker when offer is closed
                const visitorSticker = document.getElementById('liveViewersSticker');
                if (visitorSticker) {
                    (visitorSticker as HTMLElement).style.display = 'none';
                }

                console.log('🔒 Offre fermée - Sections scarcity mises à jour, boutons désactivés, sticker visiteurs masqué');
                return 0;
            }

            // Determine badge text
            const badgeText = placesRemaining > 0 ? 'OFFRE LANCEMENT 2.0' : 'PORTES FERMÉES';
            const totalPlaces = 50;
            const percentageRemaining = Math.round((placesRemaining / totalPlaces) * 100);

            // Update UI elements (new style manifest - top section)
            const scarcityBadge = document.getElementById('scarcityBadge');
            const badgeTextEl = scarcityBadge?.querySelector('.badge-text');
            const currentPlaces = document.getElementById('current-places');
            const meterFill = document.getElementById('places-meter-fill');
            const urgentCounter = document.getElementById('urgent-counter');
            const soldOutState = document.getElementById('sold-out-state');

            // Update badge (top)
            if (badgeTextEl) {
                badgeTextEl.textContent = badgeText;
            }
            
            // Update places counter (top)
            if (currentPlaces) {
                currentPlaces.textContent = placesRemaining.toString();
            }
            
            // Barre de progression = % de places RESTANTES (en rouge) - top
            if (meterFill) {
                meterFill.style.width = `${percentageRemaining}%`;
            }
            
            // Update UI elements (bottom section)
            const scarcityBadgeBottom = document.getElementById('scarcityBadge-bottom');
            const badgeTextElBottom = scarcityBadgeBottom?.querySelector('.badge-text');
            const currentPlacesBottom = document.getElementById('current-places-bottom');
            const meterFillBottom = document.getElementById('places-meter-fill-bottom');
            const urgentCounterBottom = document.getElementById('urgent-counter-bottom');

            // Update badge (bottom)
            if (badgeTextElBottom) {
                badgeTextElBottom.textContent = badgeText;
            }
            
            // Update places counter (bottom)
            if (currentPlacesBottom) {
                currentPlacesBottom.textContent = placesRemaining.toString();
            }
            
            // Barre de progression = % de places RESTANTES (en rouge) - bottom
            if (meterFillBottom) {
                meterFillBottom.style.width = `${percentageRemaining}%`;
            }
            
            // Show/hide elements
            if (urgentCounter) {
                (urgentCounter as HTMLElement).style.display = 'block';
            }
            if (urgentCounterBottom) {
                (urgentCounterBottom as HTMLElement).style.display = 'block';
            }
            if (soldOutState) {
                (soldOutState as HTMLElement).style.display = 'none';
            }

            console.log(`✅ Séquence initialisée: ${placesRemaining} places restantes / ${totalPlaces} (${percentageRemaining}% restantes)`);
            
            // Return places for visitor count function
            return placesRemaining;
        }

        // Visitor count ranges based on places remaining
        function getVisitorRange(placesRemaining: number): { min: number, max: number } {
            if (placesRemaining >= 12) {
                return { min: 8, max: 15 };
            } else if (placesRemaining >= 6) {
                return { min: 6, max: 12 };
            } else if (placesRemaining >= 3) {
                return { min: 4, max: 8 };
            } else if (placesRemaining >= 1) {
                return { min: 2, max: 5 };
            } else {
                return { min: 0, max: 0 };
            }
        }

        // Visitor count animation - linked to places remaining
        function animateVisitorCount(placesRemaining: number) {
            const visitorCountElement = document.getElementById('liveViewersCount');
            if (!visitorCountElement) return;

            const range = getVisitorRange(placesRemaining);
            if (range.min === 0 && range.max === 0) {
                visitorCountElement.textContent = '0';
                return;
            }

            let currentCount = Math.floor(Math.random() * (range.max - range.min + 1)) + range.min;
            visitorCountElement.textContent = currentCount.toString();

            // Update every 30-60 seconds
            setInterval(() => {
                // Use global places value (from Blobs, not localStorage)
                const currentRange = getVisitorRange(globalPlacesRemaining);
                
                if (currentRange.min === 0 && currentRange.max === 0) {
                    visitorCountElement.textContent = '0';
                    return;
                }

                // Variation of ±1 or ±2
                const variation = Math.floor(Math.random() * 3) - 1; // -1, 0, or 1, but we can make it ±2
                const actualVariation = Math.random() > 0.5 ? variation * 2 : variation;
                currentCount = Math.max(currentRange.min, Math.min(currentRange.max, currentCount + actualVariation));
                
                // Animate change
                visitorCountElement.style.transform = 'scale(1.05)';
                
                setTimeout(() => {
                    visitorCountElement.textContent = currentCount.toString();
                    visitorCountElement.style.transform = 'scale(1)';
                }, 200);
            }, Math.random() * 30000 + 30000);
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', async () => {
            // Initial load (API first if token, else localStorage)
            const placesRemaining = await initializeSequence();

            // Only show visitor sticker if offer is not closed
            if (placesRemaining !== undefined && placesRemaining > 0) {
                animateVisitorCount(placesRemaining);
            } else {
                // Hide visitor sticker if offer is closed
                const visitorSticker = document.getElementById('liveViewersSticker');
                if (visitorSticker) {
                    (visitorSticker as HTMLElement).style.display = 'none';
                }
            }

            // Update every minute for real-time interpolation
            setInterval(async () => {
                const currentPlaces = await initializeSequence();
                if (currentPlaces !== undefined) {
                    // Hide sticker if offer is closed
                    if (currentPlaces === 0) {
                        const visitorSticker = document.getElementById('liveViewersSticker');
                        if (visitorSticker) {
                            (visitorSticker as HTMLElement).style.display = 'none';
                        }
                        return;
                    }
                    
                    // Update visitor count range if needed
                    const visitorCountElement = document.getElementById('liveViewersCount');
                    if (visitorCountElement) {
                        const range = getVisitorRange(currentPlaces);
                        const currentCount = parseInt(visitorCountElement.textContent || '0');
                        if (currentCount < range.min || currentCount > range.max) {
                            // Adjust visitor count to new range
                            const newCount = Math.max(range.min, Math.min(range.max, currentCount));
                            visitorCountElement.textContent = newCount.toString();
                        }
                    }
                }
            }, 60000); // Every minute
        });
    </script>

