                            <div class="calculation-result">
                                <span class="result-number">124 200 €</span>
                                <span class="result-label"
                                    >Avant remboursements</span
                                >
                            </div>
                            <div class="calculation-minus">-</div>
                            <div class="calculation-step">
                                <span class="step-number">4</span>
                                <span class="step-text"
                                    >9 200 € (remboursements)</span
                                >
                            </div>
                            <div class="calculation-equals">=</div>
                            <div class="calculation-final">
                                <span class="final-number">115 000 €</span>
                                <span class="final-label">Total final</span>
                            </div>
                        </div>
                    </div>

                    <!-- Explication courte -->
                    <div class="explanation-section">
                        <p>
                            Les remboursements (Refund) bien que négligeables
