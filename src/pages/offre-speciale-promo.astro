                            </div>
                            <div class="calculation-plus">+</div>
                            <div class="calculation-step">
                                <span class="step-number">2</span>
                                <span class="step-text"
                                    >14 400 € (1ère mensualité)</span
                                >
                            </div>
                            <div class="calculation-plus">+</div>
                            <div class="calculation-step">
                                <span class="step-number">3</span>
                                <span class="step-text"
                                    >14 400 € (2ème mensualité)</span
                                >
                            </div>
