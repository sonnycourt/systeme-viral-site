---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Offre Spéciale - SYSTÈME VIRAL 100K™ - Formation Complète"
    description="Offre limitée : Formation complète + Bonus exclusifs pour générer tes premiers 10K€/mois. Garantie 30 jours satisfait ou remboursé"
    image="/media/systeme-viral-banner-final.webp"
    canonical="/offre-speciale-promo"
    noindex={true}
>
    <!-- Vérification deadline promo via API -->
    <script is:inline>
    (function() {
        fetch('https://sonnycourt.com/api/promo.json')
            .then(function(res) { return res.json(); })
            .then(function(promo) {
                if (!promo.active || Date.now() >= new Date(promo.deadline).getTime()) {
                    window.location.href = 'https://sonnycourt.com/fin-promo/';
                }
            })
            .catch(function() {});
    })();
    </script>

    <!-- Promo : banner, prix, countdown, places via API -->
    <script is:inline>
    (function() {
        fetch('https://sonnycourt.com/api/promo.json')
            .then(function(res) { return res.json(); })
            .then(function(promo) {
                var deadline = new Date(promo.deadline).getTime();

                // Banner promo
                var svBanner = promo.formations && promo.formations.systemeViral && promo.formations.systemeViral.banner;
                if (svBanner) {
                    var bannerEl = document.createElement('div');
                    bannerEl.id = 'sv-promo-banner';
                    bannerEl.style.cssText = 'position:fixed;top:0;left:0;right:0;width:100%;background:linear-gradient(105deg,#064e3b 0%,#047857 40%,#059669 100%);border-bottom:1px solid rgba(255,255,255,0.1);min-height:60px;z-index:99999;font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Helvetica Neue",sans-serif;';
                    bannerEl.innerHTML = '<div style="max-width:1400px;margin:0 auto;padding:10px 24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;justify-content:center;">' +
                        '<div style="display:flex;flex-direction:column;gap:4px;align-items:flex-start;text-align:left;">' +
                            '<span style="font-size:12px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.85);font-weight:700;">' + (svBanner.label || '') + '</span>' +
                            '<span style="font-size:22px;font-weight:900;color:#fff;line-height:1.1;">' + (svBanner.highlight || '') + '</span>' +
                        '</div>' +
                        '<div id="sv-banner-countdown" style="display:flex;align-items:center;gap:12px;background:rgba(0,0,0,0.2);border-radius:999px;padding:6px 16px;color:#fff;">' +
                            '<span style="font-size:11px;text-transform:uppercase;letter-spacing:0.8px;color:rgba(255,255,255,0.7);">Expire dans</span>' +
                            '<div style="display:flex;align-items:center;gap:10px;">' +
                                '<div style="display:flex;flex-direction:column;align-items:center;min-width:36px;"><span data-unit="days" style="font-weight:700;font-size:15px;color:#fff;">00</span><span style="font-size:9px;text-transform:uppercase;color:rgba(255,255,255,0.6);">jours</span></div>' +
                                '<div style="display:flex;flex-direction:column;align-items:center;min-width:36px;"><span data-unit="hours" style="font-weight:700;font-size:15px;color:#fff;">00</span><span style="font-size:9px;text-transform:uppercase;color:rgba(255,255,255,0.6);">heures</span></div>' +
                                '<div style="display:flex;flex-direction:column;align-items:center;min-width:36px;"><span data-unit="minutes" style="font-weight:700;font-size:15px;color:#fff;">00</span><span style="font-size:9px;text-transform:uppercase;color:rgba(255,255,255,0.6);">min</span></div>' +
                                '<div style="display:flex;flex-direction:column;align-items:center;min-width:36px;"><span data-unit="seconds" style="font-weight:700;font-size:15px;color:#fff;">00</span><span style="font-size:9px;text-transform:uppercase;color:rgba(255,255,255,0.6);">sec</span></div>' +
                            '</div>' +
                        '</div>' +
                        '<a href="https://systemeviral.spiffy.co/checkout/systeme-viral?code=FB1MILLION" target="_blank" style="background:#00dc82;color:#000;padding:10px 20px;border-radius:6px;font-weight:700;font-size:14px;text-decoration:none;white-space:nowrap;">' + (svBanner.btnText || 'Rejoindre') + '</a>' +
                    '</div>';
                    document.body.prepend(bannerEl);
                    document.body.style.paddingTop = (parseInt(document.body.style.paddingTop || '0') + bannerEl.offsetHeight) + 'px';
                    window.addEventListener('resize', function() { document.body.style.paddingTop = bannerEl.offsetHeight + 'px'; });

                    var svCountdown = document.getElementById('sv-banner-countdown');
                    function updateSvBanner() {
                        var d = deadline - Date.now();
                        function set(unit, val) { var el = svCountdown.querySelector('[data-unit="' + unit + '"]'); if (el) el.textContent = val.toString().padStart(2, '0'); }
                        if (d <= 0) { ['days','hours','minutes','seconds'].forEach(function(u){ set(u, 0); }); return; }
                        set('days', Math.floor(d / 86400000)); set('hours', Math.floor((d % 86400000) / 3600000)); set('minutes', Math.floor((d % 3600000) / 60000)); set('seconds', Math.floor((d % 60000) / 1000));
                    }
                    updateSvBanner(); setInterval(updateSvBanner, 1000);
                }

                // Badge
                var badgeEls = document.querySelectorAll('#badge-text-top, #scarcityBadge .badge-text');
                badgeEls.forEach(function(el) { el.textContent = promo.badgeText; });

                // Places proportionnel à la deadline
                var promoStart = deadline - (4 * 24 * 60 * 60 * 1000);
                var maxPlaces = 15;
                var totalPlaces = 50;
                function calcPromoPlaces() {
                    var now = Date.now();
                    if (now >= deadline) return 0;
                    if (now <= promoStart) return maxPlaces;
                    return Math.max(0, Math.ceil((1 - (now - promoStart) / (deadline - promoStart)) * maxPlaces));
                }
                function updatePlaces() {
                    var p = calcPromoPlaces();
                    var pct = Math.round((p / totalPlaces) * 100) + '%';
                    var cpEl = document.getElementById('current-places');
                    var cpBot = document.getElementById('current-places-bottom');
                    var mEl = document.getElementById('places-meter-fill');
                    var mBot = document.getElementById('places-meter-fill-bottom');
                    if (cpEl) cpEl.textContent = p.toString();
                    if (cpBot) cpBot.textContent = p.toString();
                    if (mEl) mEl.style.width = pct;
                    if (mBot) mBot.style.width = pct;
                }
                updatePlaces(); setInterval(updatePlaces, 60000);

                // Prix
                var sv = promo.formations && promo.formations.systemeViral;
                if (sv) {
                    var el1 = document.getElementById('sv-price-original');
                    var el2 = document.getElementById('sv-price-promo');
                    var el3 = document.getElementById('sv-price-installment');
                    var el4 = document.getElementById('sv-badge-desktop');
                    var el5 = document.getElementById('sv-badge-mobile');
                    if (el1) el1.textContent = sv.priceOriginal.toLocaleString('fr-FR') + '€';
                    if (el2) el2.textContent = sv.pricePromo.toLocaleString('fr-FR') + '€';
                    if (el3) el3.textContent = 'Ou seulement ' + sv.installmentCount + ' paiements de ' + sv.installmentPrice + '€';
                    if (sv.badgeText) {
                        if (el4) el4.textContent = sv.badgeText;
                        if (el5) el5.textContent = sv.badgeText;
                    }
                }

                window.__PROMO_DEADLINE__ = deadline;
            })
            .catch(function(err) { console.warn('Promo fetch failed:', err); });
    })();
    </script>

    <!-- Background effects -->
    <div class="gradient-bg"></div>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <div class="hero-badge">business en ligne</div>
                <h1 style="margin: 0 0 0 0;">
                    SYSTÈME VIRAL 100K™<br />
                    <span class="gradient-text">FORMATION COMPLÈTE</span>
                </h1>

                <p class="hero-subtitle">
                    Le système exact pour créer ton business en ligne et
                    atteindre la liberté financière avec des vidéos d'une
                    minute.
                </p>

                <div class="hero-image-container">
                    <img
                        src="/media/systeme-viral-banner-final.webp"
                        alt="Système Viral 100K"
                        class="hero-image"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features">
        <div class="container">
            <h2 class="section-title">
                Le système en <span style="color:#01e988;">3 étapes</span>
            </h2>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="step-number">1</div>
                    <h3 class="feature-title">Crée du contenu viral</h3>
                    <p class="feature-text">
                        Des vidéos d'une minute qui cartonnent.<br />
                        La formule exacte pour exploser sur tous les réseaux.<br
                        />
                    </p>
                    <div class="step-image">
                        <img
                            src="/media/SV-etape-1-ps.webp"
                            alt="Étape 1: Créer du contenu viral"
                        />
                    </div>
                    <p class="promise-container">
                        <span class="promise-text"
                            >→ Objectif : 100K vues en 30 jours</span
                        >
                    </p>
                </div>

                <div class="feature-card">
                    <div class="step-number">2</div>
                    <h3 class="feature-title">Capture les emails</h3>
                    <p class="feature-text">
                        Transforme tes vues en contacts qualifiés.<br />
                        Le système tourne H24 en automatique.<br />
                    </p>
                    <div class="step-image">
                        <img
                            src="/media/SV-etape-2-ps.webp"
                            alt="Étape 2: Capturer les emails"
                        />
                    </div>
                    <p class="promise-container">
                        <span class="promise-text"
                            >→ Objectif : 1000 leads en 60 jours</span
                        >
                    </p>
                </div>

                <div class="feature-card">
                    <div class="step-number">3</div>
                    <h3 class="feature-title">Monétise ta liste</h3>
                    <p class="feature-text">
                        Convertis ta liste en revenus récurrents.<br />
                        Affiliation ou produit propre, je te guide étape par étape.<br
                        />
                    </p>
                    <div class="step-image">
                        <img
                            src="/media/SV-etape-3-ps.webp"
                            alt="Étape 3: Monétiser ta liste"
                        />
                    </div>
                    <p class="promise-container">
                        <span class="promise-text"
                            >→ Objectif : 10K€/mois en 90 jours<br />
                            <span class="guarantee-text"
                                >(Résultats variables selon l'engagement et
                                l'effort individuel.)</span
                            ></span
                        >
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Scarcity Places - Style Manifest avec fond sombre -->
    <section class="scarcity-section">
        <div class="container">
            <h2 class="guarantee-title scarcity-title"><span class="scarcity-emoji">🚨</span> <span class="scarcity-text">DERNIÈRES PLACES DISPONIBLES !</span></h2>
            <div class="scarcity-container">
                <!-- URGENT Places Counter -->
                <div class="urgent-counter" id="urgent-counter">
                    <div class="scarcity-badge" id="scarcityBadge">
                        <span class="badge-text" id="badge-text-top">OFFRE LANCEMENT 2.0</span>
                    </div>
                    <div class="counter-header">
                        <div class="urgency-text">PLACES DISPONIBLES</div>
                    </div>

                    <div class="counter-display">
                        <div class="counter-number">
                            <span id="current-places">15</span>
                            <span class="counter-slash">/</span>
                            <span class="counter-total">50</span>
                        </div>
                        <div class="counter-label">RESTANTES</div>
                    </div>

                    <div class="urgency-meter">
                        <div class="meter-container">
                            <div class="meter-fill" id="places-meter-fill"></div>
                        </div>
                    </div>

                    <div class="warning-message" id="warning-message">
                        <div class="warning-text">
