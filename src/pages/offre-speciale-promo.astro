                rgba(185, 28, 28, 0.12) 30%,
                rgba(220, 38, 38, 0.18) 70%,
                rgba(185, 28, 28, 0.15) 100%);
            border-radius: 25px;
            padding: 40px 30px;
            border: 3px solid rgba(220, 38, 38, 0.4);
            box-shadow: 0 20px 60px rgba(220, 38, 38, 0.25);
            position: relative;
            overflow: hidden;
            animation: counterPulse 8s ease-in-out infinite;
            text-align: center;
        }

        /* Reflet premium sur le compteur */
        .urgent-counter::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 50%;
            background: linear-gradient(135deg,
                rgba(255, 255, 255, 0.1) 0%,
                rgba(255, 255, 255, 0.05) 50%,
                transparent 100%);
            border-radius: 25px 25px 0 0;
            pointer-events: none;
        }

        .urgent-counter.sold-out {
            background: linear-gradient(135deg,
                rgba(220, 38, 38, 0.12) 0%,
                rgba(185, 28, 28, 0.08) 50%,
                rgba(220, 38, 38, 0.12) 100%);
            border: 2px solid rgba(220, 38, 38, 0.3);
            box-shadow: 0 15px 40px rgba(220, 38, 38, 0.2);
            animation: none;
        }

        /* COUNTER HEADER - URGENCY FLAMES */
        .counter-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 15px;
            position: relative;
        }

        .urgency-text {
            font-size: 1.4rem;
            font-weight: 800;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-align: center;
            position: relative;
        }

        /* Style spécifique pour le titre de la section scarcity - EXACT de manifest */
        .scarcity-section .scarcity-title {
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            gap: 15px !important;
            margin-bottom: 60px !important;
            /* Override les styles de base de guarantee-title */
            font-size: inherit !important;
            background: none !important;
            -webkit-background-clip: unset !important;
            -webkit-text-fill-color: unset !important;
            background-clip: unset !important;
            text-shadow: none !important;
            line-height: inherit !important;
        }

        /* Emoji en noir/blanc normal */
        .scarcity-section .scarcity-emoji {
            font-size: 2.5rem;
            color: #000000;
            text-shadow: none;
            background: none;
            -webkit-text-fill-color: #000000;
        }

        /* Texte en rouge avec gradient */
        .scarcity-section .scarcity-text {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 50%, #991b1b 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 30px rgba(220, 38, 38, 0.5);
            animation: gradientShiftScarcity 12s ease-in-out infinite;
            font-size: clamp(2rem, 3vw, 2.8rem);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        /* Même style pour la section scarcity du bas */
        .scarcity-bottom-section .scarcity-title {
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            gap: 15px !important;
            margin-bottom: 60px !important;
            font-size: inherit !important;
            background: none !important;
            -webkit-background-clip: unset !important;
            -webkit-text-fill-color: unset !important;
            background-clip: unset !important;
            text-shadow: none !important;
            line-height: inherit !important;
        }

        .scarcity-bottom-section .scarcity-emoji {
            font-size: 2.5rem;
            color: #000000;
            text-shadow: none;
            background: none;
            -webkit-text-fill-color: #000000;
        }

        .scarcity-bottom-section .scarcity-text {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 50%, #991b1b 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 30px rgba(220, 38, 38, 0.5);
            animation: gradientShiftScarcity 12s ease-in-out infinite;
            font-size: clamp(2rem, 3vw, 2.8rem);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        /* Animation gradient shift pour le texte scarcity */
        @keyframes gradientShiftScarcity {
            0% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
            100% {
                background-position: 0% 50%;
            }
        }

        /* COUNTER DISPLAY - GIANT NUMBERS */
        .counter-display {
            text-align: center;
            margin-bottom: 30px;
            margin-top: -20px;
        }

        .counter-number {
            font-size: 6rem;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 15px;
            position: relative;
        }

        #current-places {
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gentlePulse 3s ease-in-out infinite;
        }

        .urgent-counter.sold-out #current-places {
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gentlePulse 3s ease-in-out infinite;
        }

        .counter-slash {
            font-size: 4rem;
            font-weight: 700;
            color: #dc2626;
            margin: 0 5px;
        }

        .counter-total {
            color: #666;
            font-size: 3rem;
            font-weight: 600;
        }

        .counter-label {
            font-size: 1.5rem;
            font-weight: 700;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: -35px;
        }

        /* URGENCY METER - VISUAL PROGRESS */
        .urgency-meter {
            margin-bottom: 30px;
        }

        .scarcity-section .meter-container,
        .scarcity-bottom-section .meter-container {
            width: 100%;
            height: 12px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 25px;
            overflow: hidden;
            margin-bottom: 20px;
            position: relative;
        }

        /* Barre de progression rouge comme manifest (isolé à la section scarcity) */
        .scarcity-section .meter-fill,
        .scarcity-bottom-section .meter-fill {
            height: 100%;
            background: linear-gradient(90deg, #dc2626 0%, #b91c1c 100%) !important;
            border-radius: 25px;
            transition: width 0.8s ease;
            position: relative;
        }

        .scarcity-section .meter-fill::after,
        .scarcity-bottom-section .meter-fill::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg,
                transparent 0%,
                rgba(255, 255, 255, 0.3) 50%,
                transparent 100%);
        }

        /* WARNING MESSAGE - DANGER ZONE */
        .warning-message {
            background: linear-gradient(135deg, rgba(220, 38, 38, 0.15) 0%, rgba(185, 28, 28, 0.15) 100%);
            border: 2px solid rgba(220, 38, 38, 0.4);
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
            transform: none !important;
            animation: none !important;
            transition: none !important;
        }

        .warning-message.high {
            background: linear-gradient(135deg, rgba(220, 38, 38, 0.25) 0%, rgba(185, 28, 28, 0.2) 100%);
            border-color: rgba(220, 38, 38, 0.6);
        }

        .warning-message.critical {
            background: linear-gradient(135deg, rgba(51, 51, 51, 0.3) 0%, rgba(220, 38, 38, 0.25) 100%);
            border-color: #333;
        }

        .warning-text {
            font-size: 1.1rem;
            font-weight: 700;
            color: #ffffff;
            position: relative;
            transform: none !important;
            animation: none !important;
            transition: none !important;
        }

        .warning-text strong {
            color: #ffffff;
        }

        /* CTA Section - URGENT CALL */
        .cta-section {
            text-align: center;
            margin-top: 30px;
        }

        .scarcity-cta-button {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            color: white !important;
            font-size: 1.4rem;
            font-weight: 800;
            padding: 22px 60px;
            border-radius: 50px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 15px;
            transition: all 0.3s ease;
            box-shadow:
                0 10px 40px rgba(220, 38, 38, 0.5),
                0 0 0 1px rgba(220, 38, 38, 0.3);
            border: none;
            cursor: pointer;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
            filter: none;
            -webkit-filter: none;
        }

        /* Brillance premium sur le bouton */
        .scarcity-cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg,
                transparent,
                rgba(255, 255, 255, 0.2),
                transparent);
            transition: left 0.6s ease;
        }

        .scarcity-cta-button:hover::before {
            left: 100%;
        }

        .scarcity-cta-button:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 15px 50px rgba(220, 38, 38, 0.7);
        }

        .scarcity-cta-button.sold-out {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            color: white !important;
            cursor: not-allowed;
            pointer-events: none;
            opacity: 0.8;
            transform: none;
            box-shadow: 0 10px 40px rgba(220, 38, 38, 0.5);
            filter: none !important;
            -webkit-filter: none !important;
            text-shadow: none !important;
            -webkit-text-stroke: none !important;
        }

        .scarcity-cta-button.sold-out:hover {
            transform: none;
            box-shadow: 0 10px 40px rgba(220, 38, 38, 0.5);
        }

        .cta-arrow {
            font-size: 1.4rem;
            transition: transform 0.3s ease;
        }

        .scarcity-cta-button:hover .cta-arrow {
            transform: translateX(8px);
        }

        /* Sold Out State */
        .sold-out-state {
            text-align: center;
            padding: 50px 30px;
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            border-radius: 25px;
            box-shadow: 0 15px 50px rgba(220, 38, 38, 0.4);
            animation: soldOutPulse 1s ease-in-out infinite;
            margin-top: 30px;
        }

        .sold-out-content {
            color: white;
        }

        .sold-out-title {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .sold-out-description {
            font-size: 1.1rem;
            margin-bottom: 30px;
            line-height: 1.6;
        }

        /* ANIMATIONS - PANIC EFFECTS */
        @keyframes counterPulse {
            0%, 100% {
                box-shadow: 0 15px 50px rgba(220, 38, 38, 0.25);
                transform: scale(1);
            }
            50% {
                box-shadow: 0 18px 55px rgba(220, 38, 38, 0.35);
                transform: scale(1.005);
            }
        }

        @keyframes gentlePulse {
            0%, 100% {
                transform: scale(1);
                opacity: 1;
            }
            50% {
                transform: scale(1.08);
                opacity: 0.95;
            }
        }

        @keyframes soldOutPulse {
            0%, 100% {
                transform: scale(1);
                box-shadow: 0 15px 50px rgba(220, 38, 38, 0.4);
            }
            50% {
                transform: scale(1.02);
                box-shadow: 0 20px 60px rgba(220, 38, 38, 0.6);
            }
        }

        /* Mobile Responsive - URGENT DESIGN */
        @media (max-width: 768px) {
            .scarcity-section {
                padding: 50px 0;
            }

            .urgent-counter {
                padding: 30px 20px;
                margin: 0 10px;
            }

            .counter-header {
                margin-bottom: 10px;
            }

            .counter-display {
                margin-top: -5px;
            }

            .counter-label {
                margin-top: -15px;
            }

            .urgency-text {
                font-size: 1.1rem;
            }

            .scarcity-section .scarcity-title {
                margin-bottom: 40px;
                font-size: 1.8rem;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                text-align: center !important;
            }
            
            .scarcity-section .scarcity-emoji {
                font-size: 2rem;
            }
            
            .scarcity-section .scarcity-text {
                font-size: clamp(1.5rem, 4vw, 2rem);
                text-align: center !important;
            }

            .counter-number {
                font-size: 4rem;
                gap: 5px;
            }

            #current-places {
                font-size: 4rem;
            }

            .counter-slash {
                font-size: 2.5rem;
            }

            .counter-total {
                font-size: 2rem;
            }

            .counter-label {
                font-size: 1.2rem;
                letter-spacing: 1px;
            }

            .urgency-meter {
                margin-bottom: 20px;
            }

            .warning-message {
                padding: 15px;
                margin: 20px 10px 0;
            }

            .warning-text {
                font-size: 1rem;
            }

            .scarcity-cta-button {
                font-size: 1.1rem;
                padding: 18px 40px;
                margin-bottom: 15px;
            }

            .sold-out-state {
                padding: 35px 20px;
                margin: 20px 10px 0;
            }
        }

        /* Chatbot Styles */
        #chatbot-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            font-family: "Inter", system-ui, sans-serif;
            display: none !important;
        }

        .chatbot-toggle {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(
                135deg,
                var(--accent) 0%,
                var(--accent-dark) 100%
            );
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(0, 220, 130, 0.4);
            transition: all 0.3s ease;
            position: relative;
        }

        .chatbot-toggle:hover {
            transform: scale(1.1);
            box-shadow: 0 8px 30px rgba(0, 220, 130, 0.6);
        }

        .chatbot-text {
            font-size: 11px;
            font-weight: 700;
            color: var(--bg);
            z-index: 2;
            position: relative;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
            line-height: 1.2;
        }

        .chatbot-pulse {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: 50%;
            background: rgba(0, 220, 130, 0.3);
            animation: chatbotPulse 2s ease-in-out infinite;
        }
        @keyframes chatbotPulse {
            0%,
            100% {
                transform: scale(1);
                opacity: 1;
            }
            50% {
                transform: scale(1.2);
                opacity: 0.7;
            }
        }
        .chatbot-window {
            position: absolute;
            bottom: 80px;
            right: 0;
            width: 350px;
            height: 500px;
            background: rgba(40, 40, 40, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            display: flex;
            flex-direction: column;
            transform: translateY(20px) scale(0.95);
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            overflow: hidden;
        }

        .chatbot-window::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(
                90deg,
                transparent,
                rgba(255, 255, 255, 0.3),
                transparent
            );
        }

        .chatbot-window.show {
            transform: translateY(0) scale(1);
            opacity: 1;
            pointer-events: auto;
        }

        .chatbot-header {
            padding: 16px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(50, 50, 50, 0.5);
            border-radius: 20px 20px 0 0;
            backdrop-filter: blur(10px);
        }

        .chatbot-avatar {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .avatar-icon {
            width: 20px;
            height: 20px;
            color: #fff;
        }

        .chatbot-info {
            flex: 1;
        }

        .chatbot-name {
            font-weight: 600;
            color: #f0f0f0;
            font-size: 14px;
        }

        .chatbot-status {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.6);
        }

        .status-dot {
            width: 6px;
            height: 6px;
            background: var(--accent);
            border-radius: 50%;
            animation: statusPulse 2s ease-in-out infinite;
        }

        @keyframes statusPulse {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        .chatbot-close {
            width: 24px;
            height: 24px;
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.6);
            cursor: pointer;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            transition: all 0.2s ease;
        }

        .chatbot-close:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #f0f0f0;
        }

        .chatbot-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .chatbot-messages::-webkit-scrollbar {
            width: 4px;
        }

        .chatbot-messages::-webkit-scrollbar-track {
            background: rgba(50, 50, 50, 0.3);
        }

        .chatbot-messages::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 2px;
        }

        .message {
            display: flex;
            gap: 12px;
            animation: messageSlideIn 0.3s ease;
        }

        @keyframes messageSlideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message-avatar {
            flex-shrink: 0;
        }

        .avatar-icon-small {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .avatar-icon-small svg {
            width: 16px;
            height: 16px;
            color: #01e988;
        }

        .user-message .avatar-icon-small svg {
            color: #fff;
        }

        .user-message {
            flex-direction: row-reverse;
        }

        .user-message .message-content {
            align-items: flex-end;
        }

        .user-message .message-text {
            background: var(--accent);
            color: var(--bg);
        }

        .message-content {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .message-text {
            background: rgba(60, 60, 60, 0.6);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 12px 16px;
            border-radius: 16px;
            font-size: 14px;
            line-height: 1.4;
            color: #f0f0f0;
            max-width: 250px;
            word-wrap: break-word;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .message-time {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.4);
            padding: 0 4px;
        }

        .user-message .message-time {
            text-align: right;
        }

        .typing-indicator {
            display: flex;
            gap: 12px;
            padding: 20px;
            align-items: center;
        }

        .typing-dots {
            display: flex;
            gap: 4px;
        }

        .typing-dots span {
            width: 6px;
            height: 6px;
            background: var(--accent);
            border-radius: 50%;
            animation: typingDot 1.4s ease-in-out infinite;
        }

        .typing-dots span:nth-child(1) {
            animation-delay: 0s;
        }
        .typing-dots span:nth-child(2) {
            animation-delay: 0.2s;
        }
        .typing-dots span:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes typingDot {
            0%,
            60%,
            100% {
                transform: translateY(0);
                opacity: 0.4;
            }
            30% {
                transform: translateY(-10px);
                opacity: 1;
            }
        }

        .chatbot-input-area {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(50, 50, 50, 0.5);
            border-radius: 0 0 20px 20px;
            backdrop-filter: blur(10px);
        }

        .input-container {
            display: flex;
            padding: 16px 20px;
            gap: 12px;
            align-items: center;
        }
        .chatbot-input {
            flex: 1;
            padding: 12px 16px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            background: rgba(70, 70, 70, 0.6);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            color: #f0f0f0;
            font-size: 14px;
            font-family: inherit;
            outline: none;
            transition: all 0.2s ease;
        }

        .chatbot-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(0, 220, 130, 0.1);
            background: rgba(80, 80, 80, 0.8);
        }

        .chatbot-input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }
        .chatbot-send {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--accent);
            border: none;
            color: var(--bg);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .chatbot-send:hover:not(:disabled) {
            background: var(--accent-bright);
            transform: scale(1.05);
        }
        .chatbot-send:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        .input-footer {
            padding: 0 20px 12px;
        }

        .input-hint {
            font-size: 10px;
