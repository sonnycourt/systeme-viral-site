                        <div class="proof-main-number">115 000 €</div>
                        <div class="proof-main-label">
                            Chiffre d'affaires total
                        </div>
                        <div class="proof-period">30 jours seulement</div>
                        <div class="proof-price">
                            Avec une formation ultra nichée à seulement 200 €
                        </div>
                    </div>

                    <!-- Explication du calcul -->
                    <div class="proof-calculation">
                        <div class="calculation-title">
                            Comment on arrive à 115k € :
                        </div>
                        <div class="calculation-steps">
                            <div class="calculation-step">
                                <span class="step-number">1</span>
                                <span class="step-text"
                                    >95 400 € (ventes directes)</span
