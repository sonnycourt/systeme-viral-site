            gap: 50px;
            margin-bottom: 100px;
            padding: 80px 40px 60px 40px;
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            box-shadow:
                0 16px 40px rgba(0, 0, 0, 0.3),
                inset 0 1px 1px rgba(255, 255, 255, 0.05);
            position: relative;
            opacity: 0;
            transform: translateY(40px);
            animation: secretSectionFadeIn 1s ease-out forwards;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .secret-section:nth-child(1) {
            animation-delay: 0.2s;
        }
        .secret-section:nth-child(2) {
            animation-delay: 0.4s;
        }
        .secret-section:nth-child(3) {
            animation-delay: 0.6s;
        }

        .secret-section::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(
                90deg,
                transparent,
                var(--accent),
                transparent
            );
            opacity: 0.6;
        }

        .secret-section:hover {
            transform: translateY(-8px);
            box-shadow:
                0 24px 60px rgba(0, 0, 0, 0.4),
                inset 0 1px 1px rgba(255, 255, 255, 0.08);
            border-color: rgba(0, 220, 130, 0.15);
        }
        .secret-badge {
            position: absolute;
            top: 20px;
            right: 30px;
            background: linear-gradient(135deg, var(--accent) 0%, #00f5b4 100%);
            color: #000;
            padding: 6px 12px;
            border-radius: 16px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 4px 12px rgba(0, 220, 130, 0.3);
            z-index: 30;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            opacity: 0.85;
        }

        .secret-number {
            font-size: 60px;
            font-weight: 900;
            background: linear-gradient(135deg, var(--accent) 0%, #00f5b4 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            min-width: 70px;
            text-align: center;
            line-height: 1;
            margin-top: 12px;
            text-shadow: 0 0 30px rgba(0, 220, 130, 0.3);
            flex-shrink: 0;
        }

        .secret-content {
            flex: 1;
        }

        .secret-title {
            font-size: 36px;
            font-weight: 900;
            color: var(--text-primary);
            line-height: 1.1;
            margin-bottom: 20px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        }

        .secret-subtitle {
            font-size: 22px;
            font-weight: 700;
            color: var(--accent);
            line-height: 1.4;
            margin-bottom: 35px;
            opacity: 0.9;
        }

        .secret-text {
            font-size: 19px;
            line-height: 1.8;
            color: var(--text-secondary);
            margin-bottom: 28px;
            font-weight: 400;
        }

        .secret-text p {
            margin-bottom: 24px;
        }

        .secret-text p:last-child {
            margin-bottom: 0;
        }

        .highlight-text {
            background: rgba(0, 220, 130, 0.08);
            border-left: 6px solid var(--accent);
            padding: 24px 28px;
            border-radius: 16px;
            color: var(--text-primary);
            font-weight: 700;
            font-size: 21px;
            margin: 28px 0;
            box-shadow: 0 8px 20px rgba(0, 220, 130, 0.1);
            position: relative;
        }

        .highlight-text::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(
                135deg,
                rgba(0, 220, 130, 0.02) 0%,
                rgba(0, 220, 130, 0.05) 100%
            );
            border-radius: 16px;
            z-index: -1;
        }

        .formula-container {
            background: rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 35px;
            margin: 35px 0;
            border: 1px solid rgba(255, 255, 255, 0.12);
            text-align: center;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
        }

        .formula-equation {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .formula-item {
            background: rgba(0, 220, 130, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 220, 130, 0.3);
            padding: 14px 24px;
            border-radius: 12px;
            font-weight: 800;
            font-size: 17px;
            box-shadow: 0 6px 20px rgba(0, 220, 130, 0.2);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .formula-number {
            color: var(--accent);
            font-weight: 900;
            font-size: 18px;
            text-shadow: 0 0 10px rgba(0, 220, 130, 0.5);
        }

        .formula-text {
            color: #fff;
            font-weight: 600;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
        }

        .formula-plus,
        .formula-equals {
            font-size: 28px;
            font-weight: bold;
            color: var(--accent);
            text-shadow: 0 2px 4px rgba(0, 220, 130, 0.2);
        }

        .formula-result {
            background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
            color: #000;
            padding: 14px 24px;
            border-radius: 12px;
            font-weight: 800;
            font-size: 17px;
            box-shadow: 0 6px 20px rgba(255, 107, 107, 0.4);
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
        }

        .formula-description {
            font-size: 17px;
            color: var(--text-secondary);
            font-style: italic;
            font-weight: 500;
        }
        .highlight-box {
            background: rgba(0, 220, 130, 0.08);
            border-left: 6px solid var(--accent);
            padding: 24px 28px;
            border-radius: 16px;
            margin: 28px 0;
            box-shadow: 0 8px 20px rgba(0, 220, 130, 0.1);
        }

        .highlight-box p {
            font-size: 19px;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
            line-height: 1.5;
        }

        .key-points {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            padding: 24px;
            margin: 24px 0;
            border-left: 5px solid rgba(255, 255, 255, 0.15);
            box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.05);
        }

        .key-points p {
            margin: 10px 0;
            font-size: 17px;
            color: var(--text-primary);
            font-weight: 600;
        }

        .strategy-box {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            padding: 24px;
            margin: 24px 0;
            border-left: 5px solid rgba(255, 255, 255, 0.15);
            box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.05);
        }
        .strategy-box p {
            font-size: 17px;
            color: var(--text-primary);
            margin-bottom: 18px;
            font-weight: 600;
        }

        .strategy-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .strategy-item {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .strategy-icon {
            font-size: 20px;
            flex-shrink: 0;
            margin-top: 3px;
            color: var(--accent);
        }

        .strategy-item span:last-child {
            color: var(--text-secondary);
            line-height: 1.5;
            font-size: 16px;
            font-weight: 500;
        }

        .final-thought {
            font-size: 22px;
            font-weight: 700;
            color: var(--accent);
            text-align: center;
            margin-top: 35px;
            padding: 24px 32px;
            background: rgba(0, 220, 130, 0.08);
            border-radius: 16px;
            border: 1px solid rgba(0, 220, 130, 0.25);
            box-shadow: 0 8px 25px rgba(0, 220, 130, 0.15);
            text-shadow: 0 1px 3px rgba(0, 220, 130, 0.2);
        }

        @keyframes secretSectionFadeIn {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .secrets-section {
                padding: 100px 0;
            }

            .secrets-header {
                margin-bottom: 80px;
            }

            .secret-section {
                flex-direction: column;
                align-items: center;
                gap: 35px;
                text-align: center;
                padding: 45px 30px;
                margin-bottom: 80px;
            }

            .secret-badge {
                position: static;
                margin-bottom: 20px;
                font-size: 16px;
                padding: 10px 20px;
                border-radius: 24px;
            }

            .secret-number {
                font-size: 48px;
                margin-bottom: 15px;
            }

            .secret-title {
                font-size: 30px;
            }

            .secret-subtitle {
                font-size: 20px;
            }

            .secret-text {
                font-size: 17px;
                text-align: left;
            }

            .highlight-text {
                font-size: 19px;
                padding: 20px 24px;
            }

            .formula-equation {
                flex-direction: column;
                gap: 16px;
            }

            .formula-item,
            .formula-result {
                font-size: 16px;
                padding: 12px 20px;
            }

            .formula-plus,
            .formula-equals {
                font-size: 24px;
            }

            .strategy-list {
                align-items: flex-start;
            }

            .strategy-item {
                padding: 10px 14px;
            }
        }

        @media (max-width: 480px) {
            .secrets-section {
                padding: 80px 0;
            }

            .secret-section {
                padding: 35px 24px;
                margin-bottom: 60px;
            }

            .secret-badge {
                font-size: 14px;
                padding: 8px 16px;
                margin-bottom: 15px;
            }

            .secrets-badge {
                font-size: 18px;
                padding: 16px 28px;
            }

            .secrets-subtitle {
                font-size: 19px;
            }

            .secret-title {
                font-size: 26px;
            }

            .secret-subtitle {
                font-size: 18px;
            }

            .secret-text {
                font-size: 16px;
            }

            .highlight-text {
                font-size: 18px;
                padding: 18px 20px;
            }

            .formula-container {
                padding: 25px;
            }

            .formula-item,
            .formula-result {
                font-size: 15px;
                padding: 10px 18px;
            }

            .final-thought {
                font-size: 20px;
                padding: 20px 24px;
            }
        }

        /* Target Audience Section */
        .target-audience-section {
            padding: 80px 0;
            margin-bottom: 0;
            background: linear-gradient(
                135deg,
                #0a0a0a 0%,
                #1a1a1a 50%,
                #0a0a0a 100%
            );
            position: relative;
        }

        .target-audience-section::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(
                circle at 50% 50%,
                rgba(255, 255, 255, 0.02) 0%,
                transparent 70%
            );
            pointer-events: none;
        }

        .target-header {
            text-align: center;
            margin-bottom: 60px;
            position: relative;
            z-index: 2;
        }

        .target-header .section-title {
            font-size: clamp(28px, 4vw, 42px);
            font-weight: 800;
            color: var(--text);
            line-height: 1.2;
            margin-bottom: 16px;
        }

        .target-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 40px;
            max-width: 1200px;
            margin: 0 auto;
            position: relative;
            z-index: 2;
            padding-bottom: 40px;
        }

        .target-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 30px;
            transition: all 0.3s ease;
            text-align: center;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            min-height: 600px;
            box-shadow:
                0 8px 32px rgba(0, 0, 0, 0.3),
                inset 0 1px 1px rgba(255, 255, 255, 0.1);
        }

        .target-card:hover {
            transform: translateY(-5px);
            box-shadow:
                0 12px 40px rgba(0, 0, 0, 0.4),
                inset 0 1px 1px rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.2);
        }
        .target-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(
                90deg,
                transparent,
                rgba(255, 255, 255, 0.3),
                transparent
            );
        }

        .target-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 24px;
            text-align: center;
            line-height: 1.3;
            order: -1;
        }

        .target-avatar {
            margin-bottom: 24px;
            display: flex;
            justify-content: center;
        }

        .avatar-image {
            width: 180px;
            height: 180px;
            object-fit: cover;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
        }

        .avatar-image:hover {
            transform: scale(1.05);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
        }

        .target-cta {
            margin: 24px 0 0 0;
            text-align: center;
        }
        .profile-btn {
            background: linear-gradient(
                135deg,
                var(--accent) 0%,
                var(--accent-dark) 100%
            );
            color: var(--bg);
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 4px 15px rgba(0, 220, 130, 0.3);
        }
        .profile-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 220, 130, 0.4);
        }

        .target-content {
            text-align: left;
            flex: 1;
            width: 100%;
        }

        .target-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .target-list li {
            position: relative;
            padding: 8px 0 8px 24px;
            color: var(--text-secondary);
            line-height: 1.6;
            font-size: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .target-list li:last-child {
            border-bottom: none;
        }

        .target-list li::before {
            content: "✓";
            position: absolute;
            left: 0;
            top: 8px;
            color: var(--accent);
            font-weight: 700;
            font-size: 16px;
        }

        @media (max-width: 768px) {
            .target-audience-section {
                padding: 60px 0;
                margin-bottom: 0;
            }

            .target-grid {
                grid-template-columns: 1fr;
                gap: 30px;
                padding-bottom: 30px;
            }

            .target-card {
                min-height: auto;
                padding: 24px;
            }

            .target-header .section-title {
                font-size: 28px;
            }

            .target-title {
                font-size: 20px;
            }

            .avatar-image {
                width: 140px;
                height: 140px;
            }

            .profile-btn {
                padding: 10px 20px;
                font-size: 13px;
            }

            .target-list li {
                font-size: 15px;
                padding-left: 20px;
            }

            .target-list li::before {
                font-size: 14px;
                top: 6px;
            }
        }

        /* Success Calculator Section */
        .success-calculator-section {
            padding: 80px 0;
            background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 100%);
            position: relative;
            overflow: hidden;
        }

        .success-calculator-section::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(
                circle at 50% 50%,
                rgba(0, 220, 130, 0.05) 0%,
                transparent 50%
            );
            pointer-events: none;
        }
        .calculator-header {
            text-align: center;
            margin-bottom: 60px;
        }
        .calculator-header .section-title {
            font-size: clamp(28px, 4vw, 48px);
            font-weight: 800;
            margin-bottom: 16px;
            line-height: 1.2;
        }
        .calculator-header .highlight {
            background: linear-gradient(
                135deg,
                var(--accent) 0%,
                var(--accent-bright) 100%
            );
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .calculator-header .section-subtitle {
            font-size: 18px;
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.6;
        }

        .calculator-container {
            max-width: 800px;
            margin: 0 auto;
            background: var(--bg-elevated);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .calculator-content {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(
                135deg,
                var(--accent) 0%,
                var(--accent-bright) 100%
            );
            width: 0%;
            transition: width 0.3s ease;
            border-radius: 4px;
        }
        .question-counter {
            text-align: center;
            color: var(--text-secondary);
            font-size: 16px;
            font-weight: 500;
        }

        .question-container {
            min-height: 300px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* ===== PREMIUM CALCULATOR DESIGN ===== */

        .question-card-premium {
            background: linear-gradient(
                145deg,
                rgba(25, 25, 25, 0.98),
                rgba(35, 35, 35, 0.95)
            );
            border: 2px solid rgba(0, 220, 130, 0.3);
            border-radius: 24px;
            padding: 48px;
            position: relative;
            overflow: hidden;
            animation: slideInPremium 0.8s ease-out;
            box-shadow:
                0 25px 80px rgba(0, 0, 0, 0.7),
                0 0 0 1px rgba(0, 220, 130, 0.2),
                inset 0 1px 0 rgba(255, 255, 255, 0.08),
                0 8px 32px rgba(0, 0, 0, 0.5);
        }

        /* Ensure premium styles win even if something injects base styles */
        #success-calculator .question-card-premium {
            display: block !important;
        }
        #success-calculator .options-grid-premium {
            display: grid !important;
        }
        #success-calculator .option-card-premium {
            background: rgba(255, 255, 255, 0.05) !important;
        }
        #success-calculator .question-title-premium {
            color: #fff !important;
        }

        /* Prevent external styles from leaking into the calculator */
        #success-calculator {
            isolation: isolate;
        }

        .question-card-premium::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(
                    circle at 20% 20%,
                    rgba(0, 220, 130, 0.08),
                    transparent 50%
                ),
                radial-gradient(
                    circle at 80% 80%,
                    rgba(0, 245, 142, 0.06),
                    transparent 50%
                );
            pointer-events: none;
        }

        .question-card-premium::after {
            content: "";
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(
                135deg,
                rgba(0, 220, 130, 0.3),
                rgba(0, 245, 142, 0.1),
                transparent 50%
            );
            border-radius: 24px;
            opacity: 0;
            transition: opacity 0.5s ease;
            z-index: -1;
            filter: blur(10px);
        }
        .question-card-premium:hover::after {
            opacity: 1;
        }
        @keyframes slideInPremium {
            from {
                opacity: 0;
                transform: translateY(40px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .question-header-premium {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 50px;
            position: relative;
            z-index: 2;
        }
        .question-number {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #00d4aa, #00f58e, #00d4aa);
            background-size: 200% 200%;
            animation: gradientShift 3s ease infinite;
            color: #000;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 900;
            box-shadow:
                0 10px 30px rgba(0, 220, 130, 0.5),
                0 0 0 4px rgba(0, 220, 130, 0.1),
                inset 0 2px 0 rgba(255, 255, 255, 0.3);
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
        }
        .question-number::before {
            content: "";
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent,
                rgba(255, 255, 255, 0.3),
                transparent
            );
            transform: rotate(45deg);
            animation: shimmer 3s linear infinite;
        }

        @keyframes gradientShift {
            0%,
            100% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
        }

        @keyframes shimmer {
            0% {
                transform: translateX(-100%) rotate(45deg);
            }
            100% {
                transform: translateX(100%) rotate(45deg);
            }
        }

        .question-content-premium {
            flex: 1;
        }

        .question-title-premium {
            font-size: 32px;
            font-weight: 800;
            color: #ffffff;
            line-height: 1.3;
            margin: 0 0 16px 0;
            letter-spacing: -0.5px;
        }

        @keyframes textShine {
            0%,
            100% {
                background-position: 0% center;
            }
            50% {
                background-position: 100% center;
            }
        }

        .question-decoration {
            display: none;
        }

        @keyframes decorationSlide {
            0%,
            100% {
                background-position: 0% center;
            }
            50% {
                background-position: 100% center;
            }
        }

        .options-grid-premium {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            position: relative;
            z-index: 2;
        }

        .option-card-premium {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 16px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            transform: translateY(0);
            opacity: 0;
            min-height: auto;
            box-shadow:
                0 8px 32px 0 rgba(0, 0, 0, 0.37),
                inset 0 1px 1px 0 rgba(255, 255, 255, 0.1);
        }

        .option-card-premium:hover {
            transform: translateY(-2px) scale(1.01);
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(0, 220, 130, 0.4);
            box-shadow:
                0 12px 40px 0 rgba(0, 220, 130, 0.15),
                0 8px 32px 0 rgba(0, 0, 0, 0.4),
                inset 0 1px 1px 0 rgba(255, 255, 255, 0.15);
        }

        .option-card-premium.selected-premium {
            background: rgba(0, 220, 130, 0.1);
            backdrop-filter: blur(20px) saturate(200%);
            -webkit-backdrop-filter: blur(20px) saturate(200%);
            border: 1px solid rgba(0, 220, 130, 0.5);
            box-shadow:
                0 12px 40px 0 rgba(0, 220, 130, 0.25),
                0 8px 32px 0 rgba(0, 0, 0, 0.4),
                inset 0 1px 1px 0 rgba(255, 255, 255, 0.2),
                inset 0 0 20px 0 rgba(0, 220, 130, 0.1);
            transform: translateY(-2px) scale(1.01);
        }
        .option-card-premium.selected-premium::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(
                circle at center,
                rgba(0, 220, 130, 0.1),
                transparent 70%
            );
            animation: pulse 2s ease-in-out infinite;
        }

        .option-card-inner {
            padding: 18px 20px;
            height: 100%;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .option-visual-premium {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 12px;
        }

        .option-checkbox-premium {
            position: relative;
        }

        .option-checkbox-premium input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 100%;
            height: 100%;
            margin: 0;
            cursor: pointer;
        }

        .checkbox-custom {
            width: 22px;
            height: 22px;
            border: 2px solid var(--border);
            border-radius: 6px;
            position: relative;
            transition: all 0.3s ease;
            background: var(--bg);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .option-card-premium:hover .checkbox-custom {
            border-color: var(--accent);
            transform: scale(1.1);
        }

        .option-card-premium.selected-premium .checkbox-custom {
            border-color: var(--accent);
            background: linear-gradient(
                135deg,
                var(--accent),
                var(--accent-dark)
            );
            box-shadow: 0 0 15px rgba(0, 220, 130, 0.5);
        }

        .checkbox-fill {
            width: 0;
            height: 0;
            background: white;
            border-radius: 4px;
            transition: all 0.3s ease;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .option-card-premium.selected-premium .checkbox-fill {
            width: 16px;
            height: 16px;
        }

        .checkbox-check {
            color: var(--accent);
            font-size: 14px;
            font-weight: bold;
            opacity: 0;
            transform: scale(0);
            transition: all 0.3s ease;
            position: relative;
            z-index: 1;
        }

        .option-card-premium.selected-premium .checkbox-check {
            opacity: 1;
            transform: scale(1);
            color: white;
        }

        .option-content-premium {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .option-title-premium {
            font-size: 16px;
            font-weight: 700;
            color: #ffffff;
            line-height: 1.3;
            margin: 0;
            letter-spacing: -0.2px;
            transition: all 0.3s ease;
        }

        .option-card-premium:hover .option-title-premium {
            color: var(--accent);
            text-shadow: 0 0 15px rgba(0, 220, 130, 0.25);
        }

        .option-description-premium {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.4;
            margin: 0;
            flex: 1;
            transition: color 0.3s ease;
        }

        .option-card-premium:hover .option-description-premium,
        .option-card-premium.selected-premium .option-description-premium {
            color: rgba(255, 255, 255, 0.8);
        }

        .option-glow-effect {
            position: absolute;
            top: -50%;
            left: -50%;
            right: -50%;
            bottom: -50%;
            background: radial-gradient(
                circle at center,
                rgba(0, 220, 130, 0.15),
                rgba(0, 245, 142, 0.08),
                transparent 70%
            );
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none;
            filter: blur(20px);
        }

        .option-card-premium:hover .option-glow-effect {
            opacity: 1;
            animation: glowPulse 2s ease-in-out infinite;
        }

        @keyframes glowPulse {
            0%,
            100% {
                transform: scale(1);
                opacity: 0.8;
            }
            50% {
                transform: scale(1.2);
                opacity: 1;
            }
        }

        .option-shine-effect {
            position: absolute;
            top: -100%;
            left: -100%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent 30%,
                rgba(255, 255, 255, 0.15) 50%,
                transparent 70%
            );
            transform: rotate(45deg);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            pointer-events: none;
        }
        .option-card-premium:hover .option-shine-effect {
            top: 100%;
            left: 100%;
        }
        .option-card-premium.selected-premium .option-shine-effect {
            animation: continuousShine 3s linear infinite;
        }
        @keyframes continuousShine {
            0% {
                top: -100%;
                left: -100%;
            }
            100% {
                top: 100%;
                left: 100%;
            }
        }

        /* Animation d'entrée échelonnée */
        .option-card-premium:nth-child(1) {
            animation-delay: 0.1s;
        }
        .option-card-premium:nth-child(2) {
            animation-delay: 0.2s;
        }
        .option-card-premium:nth-child(3) {
            animation-delay: 0.3s;
        }
        .option-card-premium:nth-child(4) {
            animation-delay: 0.4s;
        }

        .option-card-premium {
            animation: cardEntrance 0.6s ease-out forwards;
        }

        @keyframes cardEntrance {
            from {
                opacity: 0;
                transform: translateY(30px) scale(0.9);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        /* Responsive Design */
