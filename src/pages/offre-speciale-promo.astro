            calculateScore() {
                // Nouveaux paramètres globaux
                const BASE = 47;
                const MAX = 97;

                // Poids par question
                const WEIGHTS = {
                    q1: 10, // Temps dispo
                    q2: 12, // Motivation
                    q3: 8, // Compétences digitales / IA
                    q4: 6, // Audace / passage à l'action
                    q5: 14, // Persévérance / discipline
                };

                // Facteurs non linéaires par question (index de réponse 0..3)
                const FACTORS = {
                    q1: [0.05, 0.55, 0.85, 1.0],
                    q2: [0.1, 0.5, 0.85, 1.0],
                    q3: [0.0, 0.4, 0.75, 1.0],
                    q4: [0.0, 0.45, 0.8, 1.0],
                    q5: [0.05, 0.45, 0.8, 1.0],
                };

                // Fonction bonus de synergie
                const synergyBonus = (answers) => {
                    let bonus = 0;
                    if (answers.q2 === 3 && answers.q5 === 3) bonus += 3; // motivation + discipline max
                    if (answers.q1 >= 2 && answers.q5 >= 2) bonus += 2; // ≥1h/j + persévérance élevée
                    if (
                        [
                            answers.q1,
                            answers.q2,
                            answers.q3,
                            answers.q4,
                            answers.q5,
                        ].filter((x) => x === 3).length >= 3
                    )
                        bonus += 2; // profil élite
                    return bonus;
                };

                // Préparer les réponses dans le format attendu
                const answers = {
                    q1: this.answers[0] || 0,
                    q2: this.answers[1] || 0,
                    q3: this.answers[2] || 0,
                    q4: this.answers[3] || 0,
                    q5: this.answers[4] || 0,
                };

                // Calcul principal
                let p = BASE;
                for (const q in WEIGHTS) {
                    p += WEIGHTS[q] * FACTORS[q][answers[q]];
                }
                p += synergyBonus(answers);

                // Application des caps
                if (p > MAX) p = MAX;
                if (p < BASE) p = BASE;

                return Math.round(p);
            }
